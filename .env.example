# Copy this file to ".env" and fill in your Alpaca PAPER keys.
# Get them at https://alpaca.markets  ->  Paper Trading  ->  "View / Generate API Keys"
# NEVER commit your real .env file. (.gitignore already excludes it.)

# --- Alpaca (paper) ---
ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here
# Paper endpoint (do not change unless going live):
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Optional: Claude API for the (off-by-default) LLM analyst layer ---
# ANTHROPIC_API_KEY=

# --- Optional: Telegram bot (interact from your phone) ---
# Create a bot with @BotFather -> get the token. Get your chat id from @userinfobot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Optional: free alerting via Discord webhook (leave blank to disable) ---
# DISCORD_WEBHOOK_URL=
